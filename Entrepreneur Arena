      "parameters": {
        "jsCode": "const raw = items[0]?.json?.output || items[0]?.json?.text || '';\nconst tryParse = (v) => { try { return JSON.parse(v); } catch { return null; } };\nlet p = tryParse(raw);\nif (!p) {\n  const a = String(raw).indexOf('{'); const b = String(raw).lastIndexOf('}');\n  if (a >= 0 && b > a) p = tryParse(String(raw).slice(a, b + 1));\n}\nif (!p || typeof p !== 'object') throw new Error('Winner Packager parse failed.');\nconst verdict = $('Parse & Gate Verdict1').first().json || {};\nconst win = verdict.winningPacket || {};\nconst team = verdict.winner || '';\nconst rubric = team === 'A' ? verdict.teamARubric || {} : team === 'B' ? verdict.teamBRubric || {} : {};\nconst ks = Array.isArray(p.keyStrengths) ? p.keyStrengths.join(' | ') : '';\nconst ns = Array.isArray(p.nextSteps) ? p.nextSteps.join(' | ') : '';\nreturn [{ json: {\n  runId: verdict.runId || $execution.id,\n  runAt: verdict.runAt || new Date().toISOString(),\n  winner: team,\n  decisionStatus: verdict.decisionStatus || 'INVALID_VERDICT',\n  tieBreakTrace: verdict.tieBreakTrace || '',\n  confidenceGateReason: verdict.confidenceGateReason || '',\n  teamAConfidence: verdict.teamAConfidence || 0,\n  teamBConfidence: verdict.teamBConfidence || 0,\n  headline: p.headline || '',\n  executiveSummary: p.executiveSummary || '',\n  keyStrengths: ks,\n  nextSteps: ns,\n  justification: verdict.justification || '',\n  decisionRiskFlags: JSON.stringify(verdict.decisionRiskFlags || []),\n  teamAScore: verdict.teamAScore || 0,\n  teamBScore: verdict.teamBScore || 0,\n  conceptName: win.name || '',\n  name: win.name || '',\n  oneLiner: win.oneLiner || '',\n  targetCustomer: win.targetCustomer || '',\n  problem: win.problem || '',\n  solution: win.solution || '',\n  revenueModel: win.revenueModel || '',\n  goToMarket: win.goToMarket || '',\n  unfairAdvantage: win.unfairAdvantage || '',\n  keyRisks: win.keyRisks || '',\n  mutationApplied: win.mutationApplied || '',\n  teamStrategy: win.teamStrategy || '',\n  personaSet: win.personaSet || '',\n  personaRationale: win.personaRationale || '',\n  signalTheses: win.signalTheses || '',\n  noveltyScore: Number(win.noveltyScore || 0),\n  confidenceScore: Number(win.confidenceScore || 0),\n  horizonBucket: win.horizonBucket || '',\n  evidenceCoverage: Number(win.evidenceCoverage || 0),\n  overallStrength: win.overallStrength || 0,\n  market: Number(rubric.market || 0),\n  originality: Number(rubric.originality || 0),\n  feasibility: Number(rubric.feasibility || 0),\n  differentiation: Number(rubric.differentiation || 0),\n  distribution: Number(rubric.distribution || 0),\n  summary: win.summary || '',\n  vcQA: win.vcQA || '',\n  vcResponses: win.vcResponses || ''\n}}];"
