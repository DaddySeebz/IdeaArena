llerQuestions: ['How do first 100 customers arrive?'] },\n  { id: 'systems_arch', kind: 'archetype', displayName: 'Systems Thinker', decisionRules: ['Map dependencies'], favoredBets: ['Workflow infrastructure'], blindSpots: ['Brand pull'], antiPatterns: ['Point tools'], killerQuestions: ['What compounds?'] },\n  { id: 'deal_maker_arch', kind: 'archetype', displayName: 'Deal Maker', decisionRules: ['Partnership leverage'], favoredBets: ['Ecosystem plays'], blindSpots: ['Deep product craft'], antiPatterns: ['Go-it-alone channels'], killerQuestions: ['Who distributes this?'] }\n];\nfunction hash(str) { let h = 2166136261; for (let i = 0; i < str.length; i++) { h ^= str.charCodeAt(i); h = Math.imul(h, 16777619); } return (h >>> 0); }\nfunction sortBySeed(arr, salt) { return [...arr].sort((a,b) => hash(runSeed + salt + a.id) - hash(runSeed + salt + b.id)); }\nconst named = sortBySeed(personaPool.filter(p => p.kind === 'named'), 'named');\nconst arch = sortBySeed(personaPool.filter(p => p.kind === 'archetype'), 'arch');\nreturn [{ json: {\n  runId: $execution.id,\n  runAt: new Date().toISOString(),\n  runSeed,\n  constraints,\n  rubric,\n  confidenceThreshold,\n  personaPoolVersion: 'v2.1',\n  teamConfigs: {\n    A: { teamWorkflowId: teamAWorkflowId, teamStrategy: 'inventor_lab', assignedPersonas: [named[0], arch[0]] },\n    B: { teamWorkflowId: teamBWorkflowId, teamStrategy: 'operator_forge', assignedPersonas: [named[1], arch[1]] }\n  }\n}}];"
