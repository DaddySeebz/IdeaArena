cket.overallStrength || 0,\n    market: winnerTeam === 'A' ? judge.teamARubric?.market || 0 : judge.teamBRubric?.market || 0,\n    originality: winnerTeam === 'A' ? judge.teamARubric?.originality || 0 : judge.teamBRubric?.originality || 0,\n    feasibility: winnerTeam === 'A' ? judge.teamARubric?.feasibility || 0 : judge.teamBRubric?.feasibility || 0,\n    differentiation: winnerTeam === 'A' ? judge.teamARubric?.differentiation || 0 : judge.teamBRubric?.differentiation || 0,\n    distribution: winnerTeam === 'A' ? judge.teamARubric?.distribution || 0 : judge.teamBRubric?.distribution || 0,\n    summary: winningPacket.summary || ''\n  }\n}];"
